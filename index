        /* ─── EDUCATION ─── */
        .edu-list { max-width: 800px; margin: 0 auto; }
        .edu-item {
            margin-bottom: 2rem;
            padding-left: 1.5rem;
            border-left: 3px solid var(--primary);
        }
        .edu-item h3 { font-size: 1rem; }
        .edu-item p { color: var(--text-light); font-size: 0.9rem; margin-top: 0.3rem; }

        /* ─── FOOTER ─── */
        footer {
            text-align: center;
            padding: 2.5rem;
            background: #f1f5f9;
            color: var(--text-light);
            font-size: 0.9rem;
        }

        /* ─── RESPONSIVE: TABLET ─── */
        @media (max-width: 900px) {
            .about-grid {
                grid-template-columns: 1fr;
                gap: 2.5rem;
                text-align: center;
            }

            .about-grid > div:last-child { text-align: left; }
        }

        /* ─── RESPONSIVE: MOBILE ─── */
        @media (max-width: 768px) {
            :root { --nav-height: 60px; }

            .logo { font-size: 1.4rem; }

            /* Hide desktop nav, show hamburger */
            .nav-links { display: none; }
            .hamburger { display: flex; }

            .hero { padding-top: calc(var(--nav-height) + 1.5rem); }

            .section-title { margin-bottom: 2rem; }

            .projects-grid { grid-template-columns: 1fr; }

            .about-grid {
                grid-template-columns: 1fr;
                gap: 2rem;
                text-align: center;
            }

